From: ps2_arm64_toolchain Project 006
Subject: [PATCH] Allow optional PS2DEV_JOBS override
Upstream-base: ps2dev/ps2toolchain-dvp 54d25004c9d9d0d10d5f320703a8fe7c6ddb684a
Purpose: Permit resource-constrained hosts to select a safe build job count.
Behavior: PS2DEV_JOBS overrides the job count when set; an unset variable retains getconf exactly.
Validation: Applied and validated by Project 006; see BUILD_LOG.md.

diff --git a/scripts/001-binutils.sh b/scripts/001-binutils.sh
--- a/scripts/001-binutils.sh
+++ b/scripts/001-binutils.sh
@@ -51,7 +51,7 @@ if [ "$(uname -s)" = "Darwin" ]; then
 fi
 
 ## Determine the maximum number of processes that Make can work with.
-PROC_NR=$(getconf _NPROCESSORS_ONLN)
+PROC_NR=${PS2DEV_JOBS:-$(getconf _NPROCESSORS_ONLN)}
 
 ## For each target...
 for TARGET_ALIAS in "dvp"; do
diff --git a/scripts/002-masp.sh b/scripts/002-masp.sh
--- a/scripts/002-masp.sh
+++ b/scripts/002-masp.sh
@@ -31,7 +31,7 @@ cd "$REPO_FOLDER"
 fi
 
 ## Determine the maximum number of processes that Make can work with.
-PROC_NR=$(getconf _NPROCESSORS_ONLN)
+PROC_NR=${PS2DEV_JOBS:-$(getconf _NPROCESSORS_ONLN)}
 
 ## Configure, build, and install.
 cmake -S "$REPO_FOLDER" -B "$REPO_FOLDER/build" \
diff --git a/scripts/003-openvcl.sh b/scripts/003-openvcl.sh
--- a/scripts/003-openvcl.sh
+++ b/scripts/003-openvcl.sh
@@ -31,7 +31,7 @@ cd "$REPO_FOLDER"
 fi
 
 ## Determine the maximum number of processes that Make can work with.
-PROC_NR=$(getconf _NPROCESSORS_ONLN)
+PROC_NR=${PS2DEV_JOBS:-$(getconf _NPROCESSORS_ONLN)}
 
 ## Configure, build, and install.
 cmake -S "$REPO_FOLDER" -B "$REPO_FOLDER/build" \
